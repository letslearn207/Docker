#overlay network

docker network create -d overlay my-overlay-net
docker network ls

docker service create \
  --name backend \
  --network my-overlay-net \
  --replicas 2 \
  alpine \
  sleep 10000

Check:
docker service ps backend

#Deploy frontend

docker service create \
  --name frontend \
  --network my-overlay-net \
  --replicas 2 \
  -p 8080:80 \
  nginx

The app is exposed on: http://<ANY-NODE-IP>:8080


